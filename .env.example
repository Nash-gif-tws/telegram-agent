TELEGRAM_BOT_TOKEN=       # from @BotFather
ANTHROPIC_API_KEY=        # from console.anthropic.com
ALLOWED_TELEGRAM_IDS=     # your Telegram user ID (get from @userinfobot)
WEBHOOK_URL=              # your Railway URL e.g. https://xxx.up.railway.app

# Optional — for tool access
RENTAL_DATABASE_URL=      # your rental-system Postgres URL from Railway
SHOPIFY_STORE_URL=        # e.g. snowskierswarehouse.myshopify.com
SHOPIFY_ADMIN_TOKEN=      # Shopify Admin API token
